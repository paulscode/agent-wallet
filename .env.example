# ══════════════════════════════════════════════════════════════════════
# Agent Wallet — Environment Configuration
# ══════════════════════════════════════════════════════════════════════
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Application ──
# ⚠ BACKUP IMMEDIATELY — SECRET_KEY encrypts all Boltz swap private
#   keys and preimages at rest. If it is lost while any swap is
#   in-flight, the wallet can no longer cooperatively claim, refund,
#   or unilaterally refund those swaps; funds depend on Boltz's
#   timeout behaviour. start.sh writes a narrow backup file
#   (secret-key-backup-<timestamp>.txt, mode 0600) when it generates
#   a fresh value — move that file to offline storage (USB, paper,
#   password manager) immediately. To rotate, move the existing
#   value into SECRET_KEY_PREVIOUS and put the new value here.
SECRET_KEY=change-me-to-a-random-64-char-string
# SECRET_KEY_PREVIOUS=  # set during a rotation; can decrypt existing rows
# Read pre-v2 (static-salt) encrypted fields at runtime. Leave false; the
# field-format upgrade migration reads them regardless, so this only needs
# enabling for a manual read of un-migrated rows.
# ALLOW_STATIC_SALT_FIELD_DECRYPTION=false
DEBUG=false
LOG_LEVEL=info
LOG_FORMAT=text
# LOG_FORMAT=json  # Structured JSON logging (requires: pip install agent-wallet[json-logging])
# Bind address. Loopback by default so the API is not exposed on all
# interfaces. Set to 0.0.0.0 only when fronted by a reverse proxy, and
# set TRUSTED_PROXIES to the proxy CIDR when you do.
API_HOST=127.0.0.1
API_PORT=8100
# Expose /docs, /redoc, and /openapi.json. Off by default; enable only
# where you intend the interactive docs to be reachable.
ENABLE_DOCS=false
# Set the Secure flag on auth cookies. Set to false ONLY for plain-HTTP
# local development; leave true behind any TLS terminator.
COOKIE_SECURE=true
# Maximum API key lifetime in days (server-side cap on requested expiry).
API_KEY_MAX_TTL_DAYS=365

# Reverse-proxy CIDRs allowed to set X-Forwarded-For. Required when
# the dashboard is exposed behind a reverse proxy (nginx, Caddy,
# Cloudflare). Without this, request.client.host is the proxy's
# address — identical for every user — and dashboard session
# IP-binding silently provides no protection. Comma-separated or
# JSON array, e.g. "172.16.0.0/12" or '["10.0.0.0/8","192.168.0.0/16"]'.
TRUSTED_PROXIES=

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://agent_btc_wallet:__REPLACE_ME__@postgres:5432/agent_btc_wallet_db
# For running tests locally (outside Docker):
# DATABASE_URL=postgresql+asyncpg://agent_btc_wallet:__REPLACE_ME__@localhost:5433/agent_btc_wallet_db
# Require SSL/TLS for database connections (recommended for remote/managed databases)
DATABASE_REQUIRE_SSL=false

# Docker Compose database credentials (used by docker-compose.yml)
# Replace BOTH literals before booting. start.sh refuses to launch
# while either side equals __REPLACE_ME__.
POSTGRES_PASSWORD=__REPLACE_ME__
REDIS_PASSWORD=__REPLACE_ME__

# ── Redis (for Celery task queue + rate limiting) ──
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── LND Node Connection ──
# REST API endpoint of your LND node
LND_REST_URL=https://your-lnd-host:8080

# Hex-encoded admin macaroon (required)
# Get it: xxd -ps -u -c 1000 ~/.lnd/data/chain/bitcoin/mainnet/admin.macaroon
# Or from lndconnect URI (auto-parsed in setup)
LND_MACAROON_HEX=

# Verify the LND node's TLS certificate. Keep true. For a self-signed
# home node (Start9/Umbrel), pin the cert via LND_TLS_CERT below instead
# of disabling verification — disabling it exposes the admin macaroon to
# an on-path attacker on clearnet/LAN links.
LND_TLS_VERIFY=true

# Optional: base64-encoded TLS certificate (from lndconnect URI or manual).
# Set this to pin a self-signed cert while keeping LND_TLS_VERIFY=true.
LND_TLS_CERT=

# ── Tor Proxy (for .onion LND nodes) ──
# Set if your LND node is accessed via Tor (e.g., Start9 servers)
# The tor-proxy container provides SOCKS5 proxy at socks5://tor-proxy:9050
LND_TOR_PROXY=
# Example for Start9: LND_TOR_PROXY=socks5://tor-proxy:9050
#
# Operator-supplied Tor. If you already run your own Tor on
# the host (Whonix / Tails / a hardened SOCKS proxy), point at it
# instead and disable the bundled tor-proxy container. The SOCKS5
# round-trip startup check confirms the configured proxy is
# actually reachable; an unreachable proxy logs a clear error to
# docker logs so you can fix it on first boot.
# Examples:
#   - Docker Desktop on macOS/Windows:
#       LND_TOR_PROXY=socks5://host.docker.internal:9050
#   - Linux host networking:
#       LND_TOR_PROXY=socks5://172.17.0.1:9050
# When pointing at a host Tor, ALSO disable the bundled service with:
#       docker compose --profile no-bundled-tor up -d
# (see docs/operator_tor_runbook.md for the operator-supplied-Tor
# checklist).

# Tor control-port password.
# The wallet uses Tor's ControlPort (bound to 127.0.0.1:9100 in the
# tor-proxy container) for bootstrap probes, circuit diagnostics, and
# the NEWNYM watchdog that auto-recovers wedged circuits. Set this to
# a strong random string; the same value is used by:
#   - the tor-proxy entrypoint shim to derive HashedControlPassword
#   - the api container to authenticate when issuing GETINFO / SIGNAL
# Empty leaves the control port unauthenticated (dev-default; the
# entrypoint shim logs a warning). For production, generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
TOR_CONTROL_PASSWORD=

# ── Tor robustness knobs (all optional; defaults shipped) ──
# Most operators never need to touch these — the defaults are tuned
# from the 2026-05-21 incident postmortem.
#
# Preventive Tor age rotation cadence (days). The Celery beat
# task fires SIGNAL HUP at this interval to prevent guard-state
# degradation from accumulating. Set to 0 to disable the rotation
# task entirely (e.g. when running an operator-supplied Tor with a
# separate rotation policy).
TOR_ROTATION_INTERVAL_DAYS=7
#
# Minimum seconds between NEWNYM signals fired by the
# watchdog. Tor enforces 10s as a hard floor; the wallet uses a
# longer cadence so we don't thrash circuits during a flapping
# outage.
TOR_NEWNYM_MIN_INTERVAL_S=60
#
# Watchdog tick cadence (seconds). Also drives the
# "watchdog unhealthy" threshold in the dashboard panel (>3× this
# value with no tick = unhealthy).
TOR_WATCHDOG_INTERVAL_S=30
#
# Consecutive Tor-classified failures before the Tor breaker
# opens. The watchdog observes this transition and starts the
# escalation timer (NEWNYM → SIGHUP → healthcheck restart).
TOR_BREAKER_FAILURE_THRESHOLD=5
#
# LND HS descriptor freshness check cadence (seconds).
# Default 21600 = 6 hours. A failed fetch across two consecutive
# ticks emits a stale-descriptor audit warning (operator-actionable
# signal that LND-side publish is broken).
TOR_HS_DESCRIPTOR_CHECK_INTERVAL_S=21600
#
# ── LND Tor supervisor (stale-HS-descriptor auto-recovery) ──
# The supervisor watches _LND_BREAKER + corroborating signals
# (other-onion probe, HSFETCH) and runs a staggered ladder —
# HSFETCH → NEWNYM → SIGHUP → healthcheck → exhausted — when LND's
# hidden service goes unreachable via our Tor proxy. See
# docs/anonymize_troubleshooting.md "Request timed out — the node
# may be unreachable". Motivated by stale-descriptor incidents where
# LND's hidden service becomes unreachable via the Tor proxy.
#
# Master kill switch. ``false`` reverts to the legacy single-watchdog behaviour
# (the existing tor_watchdog still fires NEWNYM at ~60 s on a
# Tor-classified LND failure; this knob disables the supervisor's
# additional surgical HSFETCH step + cycle-cap policy).
LND_TOR_RECOVERY_ENABLED=true
# How long _LND_BREAKER must be open before C1 evaluates true
# (the "sustained failure" threshold). Must be ≤ the natural
# half-open interval of _LND_BREAKER (30 s) plus a few keepalive
# ticks.
LND_TOR_RECOVERY_DETECT_WINDOW_S=60
# HSFETCH stage maximum wall time. Tor HSDir lookups can take
# ~30-60 s; we wait up to this long for an HS_DESC event.
LND_TOR_RECOVERY_HSFETCH_TIMEOUT_S=60
# After step 2 (NEWNYM), wait this long for the breaker to close
# before escalating to step 3.
LND_TOR_RECOVERY_NEWNYM_WAIT_S=90
# After step 3 (SIGHUP), wait this long before yielding to the
# Docker healthcheck (step 4).
LND_TOR_RECOVERY_SIGHUP_WAIT_S=120
# Rolling 24 h cycle cap. 4+ cycles in 24 h disables the
# supervisor for the rest of the window — chronic LND-side
# issues shouldn't look like a healthy auto-recovery loop.
LND_TOR_RECOVERY_MAX_CYCLES_PER_DAY=4
# C3 corroborating probe target. Empty → auto-resolve from
# LND_MEMPOOL_URL / LND_ELECTRUM_URL (first .onion wins). The
# supervisor probes up to 2 endpoints per detection; ≥1 success
# clears C3.
LND_TOR_RECOVERY_OTHER_ONION_PROBE_URL=
# Per-probe timeout for the C3 onion reachability check.
LND_TOR_RECOVERY_OTHER_ONION_TIMEOUT_S=10
# Backoff durations between cycles. Cycle 1 → 2 uses _15M_S,
# 2 → 3 uses _45M_S, 3 → 4 uses _2H_S; 4+ → disabled until the
# rolling 24 h window slides.
LND_TOR_RECOVERY_COOLDOWN_15M_S=900
LND_TOR_RECOVERY_COOLDOWN_45M_S=2700
LND_TOR_RECOVERY_COOLDOWN_2H_S=7200
#
# DataDirectory growth threshold (MB). Watchdog emits an
# audit warning when the mounted /var/lib/tor volume exceeds this
# size. Tor steady-state is ~10-30 MB; >100 MB is operator-attention.
TOR_DATA_DIR_WARN_MB=100
#
# Path the watchdog statvfs()s for the growth check. Set
# empty to disable (operators running their own Tor outside the
# compose stack).
TOR_DATA_DIR_MOUNT_PATH=/var/lib/tor
#
# Startup exit-relay diversity smoke test. When ``true``,
# lifespan startup blocks on the smoke test; a circuit-collision
# failure aborts the process before traffic is accepted (the "fail
# loud" behaviour). Default ``false`` runs the
# smoke test as a background task — collisions are logged but
# don't refuse to serve.
TOR_DIVERSITY_SMOKE_BLOCKING=false
#
# Tor split mode. ``true`` runs separate tor-lnd and
# tor-anonymize processes (requires bringing up the stack with
# ``docker compose -f docker-compose.yml -f docker-compose.tor-split.yml``).
# Default ``false`` runs the unified ``tor-proxy``.
TOR_SPLIT_MODE=false
ANONYMIZE_TOR_SOCKS_HOST=tor-proxy
# Clearnet endpoint used by the three Tor SOCKS5 health probes
# (one-shot reach check at startup, diversity smoke at startup,
# per-listener round-robin every 30 s). NOT used for any actual
# chain data — purely a "did the SOCKS5 round-trip succeed?"
# target. Default is Cloudflare's DNS resolver trace endpoint:
# small text response, anycast-backed, no Bitcoin-project
# association. Operators who want a Bitcoin-themed probe target
# can point this at any cheap public endpoint that returns 2xx
# to GET, e.g. https://bitcoinexplorer.org/api/blocks/tip/height
# (Jameson Lopp's instance — community-aligned).
TOR_PROBE_URL=https://1.1.1.1/cdn-cgi/trace
# Tor ControlPort the wallet uses for bootstrap probes,
# NEWNYM watchdog, SETEVENTS stream, HSFETCH descriptor check, and
# per-listener / diversity probes. Default points at the bundled
# tor-proxy container's ControlPort (per tor-proxy/torrc). If you
# run your own Tor on the host, override to host.docker.internal
# (macOS/Windows) or the host bridge IP (Linux) and ensure that
# Tor's torrc exposes a reachable ControlPort.
ANONYMIZE_TOR_CONTROL_HOST=tor-proxy
ANONYMIZE_TOR_CONTROL_PORT=9100
LND_TOR_CONTROL_HOST=
LND_TOR_CONTROL_PORT=9100
#
# Deliberate deviations from plan (intentionally NOT exposed
# as env knobs):
#   - TOR_VERSION_PIN: an earlier design considered apk-pin via env, but the
#     Dockerfile pins the Alpine base image (3.20) at build-time
#     instead — a test in tests/unit/test_tor_proxy_compose_and_dockerfile.py
#     enforces this. Bumping requires editing the Dockerfile + test
# deliberately.
#   - TOR_METRICS_TOKEN: an earlier design considered a separate metrics-only
#     token; the actual endpoint at /v1/status/tor/metrics is gated
#     by admin-key auth (existing get_admin_key dependency), which
#     is strictly stronger. No separate token is needed.
#   - TOR_HEALTH_PROBE_INTERVAL_S: the dashboard panel is refreshed
#     on operator click rather than auto-polled. No auto-poll cadence
#     to tune. Dashboard background indicator updates with each
#     manual refresh.

# ── Mempool Explorer ──
# Used for fee estimation and transaction link generation
# Default: public mempool.space. Use your own instance for privacy.
LND_MEMPOOL_URL=https://mempool.space
# Example self-hosted: LND_MEMPOOL_URL=https://mempool.your-domain.local:4080
# Disable only for self-hosted instances with self-signed certs.
MEMPOOL_TLS_VERIFY=true
# SSRF guard: by default the app refuses to start if LND_MEMPOOL_URL
# resolves to a private/loopback/link-local address. Set to true ONLY
# when you are deliberately pointing at a self-hosted internal instance
# on a private subnet. Onion / .local hostnames are always allowed.
MEMPOOL_ALLOW_INTERNAL=false
# Public mempool URL the dashboard UI links to for "View on mempool"
# affordances. Leave empty to derive from LND_MEMPOOL_URL when it's
# clearnet; falls back to https://mempool.space for onion / unset
# configurations (so links stay usable from a normal browser).
# Most home-node users (Start9, Umbrel, myNode) want their LAN-local
# mempool here, e.g. http://umbrel.local:3006 or http://192.168.1.50:3006.
MEMPOOL_PUBLIC_URL=

# ── Chain backend (optional electrs / Electrum server) ──
# Privacy upgrade for Start9-style deployments: route address lookups,
# transaction confirmation polling, fee estimation and Boltz timeout
# checks through your own electrs instance instead of mempool.space.
#
#   auto     → use electrs when LND_ELECTRUM_URL is set; transparently
#              fall back to LND_MEMPOOL_URL if electrs is unreachable.
#              This is the recommended mode (default).
#   electrum → require electrs; fail loud at startup if unreachable.
#              No HTTP fallback. Choose this when you do NOT want any
#              third-party mempool.space traffic.
#   mempool  → ignore LND_ELECTRUM_URL and use the HTTP backend only
#              (the legacy behaviour).
CHAIN_BACKEND=auto
# Route clearnet chain-backend traffic (mempool HTTP / Electrum) through the
# Tor SOCKS proxy. .onion/.local hosts always use the proxy regardless.
#   true   → always proxy clearnet hosts (resolved remotely at the proxy so
#            the host IP and queried addresses stay off the clearnet path).
#            Requires LND_TOR_PROXY.
#   false  → connect to clearnet hosts directly.
#   auto   → proxy clearnet hosts iff LND_REST_URL is a .onion host. Default.
CHAIN_BACKEND_FORCE_TOR=auto
# Electrum/electrs endpoint. Examples:
#   tcp://localhost:50001            — same-host plaintext
#   ssl://electrs.local:50002        — LAN over TLS (set MEMPOOL/electrs cert)
#   tcp://abcd…xyz.onion:50001       — hidden-service (requires LND_TOR_PROXY)
# Leave blank to disable the electrum backend (mempool.space only).
LND_ELECTRUM_URL=
# Verify the server's TLS chain when the URL is ssl://. Set to false for
# self-signed certs (typical Start9 setup); ignored for tcp:// and .onion.
LND_ELECTRUM_TLS_VERIFY=true
# Optional pinned CA bundle (PEM file path or base64-encoded PEM) for
# self-signed electrs certificates. Lets you keep TLS verification on.
LND_ELECTRUM_CA_CERT=
# Keepalive ping interval (seconds). Detects dropped connections faster.
LND_ELECTRUM_PING_INTERVAL_S=30
# Per-RPC and connect timeouts (seconds).
LND_ELECTRUM_REQUEST_TIMEOUT_S=8
LND_ELECTRUM_CONNECT_TIMEOUT_S=10
# Max concurrent scripthash subscriptions (caps receive-address watcher
# fan-out). Default 256 is plenty for typical wallets.
LND_ELECTRUM_MAX_SUBSCRIPTIONS=256

# ── Safety Limits ──
# Maximum sats allowed per single payment (-1 = no limit, 0 = all require approval)
LND_MAX_PAYMENT_SATS=10000
# Cumulative spending limit in rolling window (0 = disabled)
LND_RATE_LIMIT_SATS=100000
# Rolling window for rate limit in seconds (default: 1 hour)
LND_RATE_LIMIT_WINDOW_SECONDS=3600
# Max send transactions per velocity window before circuit breaker trips (0 = disabled)
LND_VELOCITY_MAX_TXNS=5
# Velocity window in seconds (default: 15 minutes)
LND_VELOCITY_WINDOW_SECONDS=900

# Behaviour when Redis is unavailable: "closed" (default, recommended)
# refuses payment-rate-limited and dashboard-session requests so caps
# cannot be bypassed; "open" allows them through. The dashboard's
# session validation (revocation, idle timeout, IP binding) also
# honours this — under "closed" a Redis outage forces re-login rather
# than degrading silently to signature-only validation.
RATE_LIMIT_FAIL_POLICY=closed

# Global SlowAPI default cap applied per-client-IP across all routes
# that don't declare their own @limiter.limit(...). Authenticated
# dashboard sessions naturally fan out many small polls (balances,
# sessions, channels, fees, Braiins quotes, etc.) so the upstream
# 60/minute default trips 429s in normal use. Tighter per-endpoint
# caps still apply to login, /sign/*, payments, and CSRF mutations
# via explicit decorators.
SLOWAPI_DEFAULT_LIMIT=240/minute

# ── Boltz Exchange (Cold Storage — Lightning → On-Chain swaps) ──
BOLTZ_API_URL=https://api.boltz.exchange/v2
BOLTZ_ONION_URL=http://boltzzzbnus4m7mta3cxmflnps4fp7dueu2tgurstbvrbt6xswzcocyd.onion/api/v2
# Route Boltz API calls via Tor proxy for privacy
BOLTZ_USE_TOR=true
# Fall back to clearnet if Tor is unavailable (less private but more reliable)
BOLTZ_FALLBACK_CLEARNET=false

# ── Braiins Deposit (round-amount deposit to Braiins Hashpower) ──
# See docs/braiins_deposit.md.
# Master kill-switch; when false the On-chain-tab button is hidden and
# the API surface 404s.
BRAIINS_DEPOSIT_ENABLED=true
# Confirmations required on the fresh Boltz claim UTXO before we send
# to the destination. 1 is reasonable on mainnet; raise to 2-3 for
# noisy chains / paranoid setups.
BRAIINS_DEPOSIT_CONFIRMATIONS_BEFORE_SEND=1
# Confirmation threshold for the BROADCAST -> COMPLETED state
# transition of the final send-to-Braiins tx.
BRAIINS_DEPOSIT_CONFIRMATIONS_FOR_COMPLETION=1
# Blocks-since-broadcast before we surface a non-fatal "tx hasn't
# confirmed" warning. ~144 ≈ 1 day at 10 min/block.
BRAIINS_DEPOSIT_BROADCAST_STUCK_BLOCKS=144
# Extra headroom on the Boltz invoice amount above the round deposit
# + estimated send fee, to absorb fee drift between quote and send.
BRAIINS_DEPOSIT_SAFETY_BUFFER_SATS=1000
# Percent drift between the wizard's submitted quote and a fresh
# server-side re-quote before we 409 and force re-confirmation.
BRAIINS_DEPOSIT_QUOTE_STALENESS_PCT=10
# Continuous LND-unavailability window before a "stuck for Ns" warning
# is appended to the session's error_message (never auto-FAIL).
BRAIINS_DEPOSIT_LND_TRANSIENT_MAX_AGE_S=3600
# Max dwell time in CREATED before a non-fatal warning is surfaced
# on the session detail.
BRAIINS_DEPOSIT_CREATED_TTL_S=300
# Default on-chain fee priority for the final send to Braiins
# (low / medium / high). Operators can override per-session via the
# wizard's Advanced disclosure.
BRAIINS_DEPOSIT_SEND_FEE_PRIORITY=medium
# Dust prevention.
# When true (default), the send tx is single-input/single-output:
# the entire fresh UTXO goes to Braiins minus the network fee. No
# wallet-side change UTXO is ever created. Trade-off: the arrival
# amount at Braiins is the bin amount as a FLOOR (not exact); the
# wallet may overpay by up to the safety buffer in low-fee
# environments, which becomes additional hashpower credit. Flip to
# false ONLY for fast rollback if the new send path misbehaves;
# the legacy path produces dust change at high fees and should be
# retired after one stable release.
BRAIINS_DEPOSIT_DUST_PREVENTION_ENABLED=true
# When a session can't broadcast at current fees (the dust-safe
# projection underpays the bin), it parks in AWAITING_FEE_REDUCTION
# and the advance loop reconsiders feasibility this often (seconds).
BRAIINS_DEPOSIT_FEE_REDUCTION_RECHECK_S=300

# ── Anonymize: distinct-operator splitting ──
# On-chain anonymize sessions use two operators — one per swap leg —
# so neither operator alone sees both ends of the mix. The default
# policy puts canonical Boltz on the REVERSE leg (where the
# destination address is visible) and a curated alt operator on the
# SUBMARINE leg, with a pre-funding fallback chain so a single alt
# outage doesn't force the user to abandon their session.
#
# Default chain (all three blank): Middleway → Eldamar →
# user-consented single-operator-Boltz (capped at moderate tier).
#
# Override the chain by setting any of these to a specific
# operator_id from your loaded operators.json.
ANONYMIZE_SUBMARINE_OPERATOR_PRIMARY=
ANONYMIZE_SUBMARINE_OPERATOR_SECONDARY=
ANONYMIZE_REVERSE_OPERATOR=

# Probe timeout for the pre-funding reachability check. Tor
# first-circuit-to-onion can be 3-5 s; 6 s covers cold-start without
# false-positive flapping. Tighten only if you know your circuits
# are fast.
ANONYMIZE_OPERATOR_PROBE_TIMEOUT_S=6.0
# In-memory probe-result cache TTL. Short enough that the cache
# doesn't outlive a typical wizard interaction (1-3 min); long
# enough that filling out the form doesn't re-probe per field.
ANONYMIZE_OPERATOR_PROBE_CACHE_TTL_S=60.0

# Power-user URL pin — setting either bypasses the chain logic and
# disables the pre-funding fallback for that leg. Leave blank to
# keep the chain-driven defaults above. See
# docs/anonymize_operator_diversity.md for the diligence checklist
# + research pointers (SwapMarket, etc.).
BOLTZ_SUBMARINE_ONION_URL=
BOLTZ_REVERSE_ONION_URL=

# ── Network ──
# bitcoin, testnet, signet, regtest — determines address validation and Boltz endpoints
BITCOIN_NETWORK=bitcoin

# ── Security (TLS / HSTS) ──
# Sends the Strict-Transport-Security header and reinforces the Secure
# flag on dashboard session cookies. Keep enabled whenever TLS
# terminates at this service or a reverse proxy in front of it. Set to
# false only for a plain-HTTP / Tor-only deployment with no TLS, where
# HSTS would pin an unreachable https scheme.
ENABLE_HSTS=true

# ── Dashboard ──
# Token to access the web dashboard at /dashboard/
# If not set, a random token is auto-generated and written to .env on first startup.
# DASHBOARD_TOKEN=
ENABLE_DASHBOARD=true
# Session lifetime in hours (1–24). Idle timeout is clamped to this.
DASHBOARD_SESSION_HOURS=4
DASHBOARD_IDLE_TIMEOUT_MINUTES=30
# Optional per-payment cap for dashboard operations (-1 = no limit)
# DASHBOARD_MAX_PAYMENT_SATS=-1
# Lightning Address for the dashboard's 'Tip the developer' dialog.
# Forks should set their own, or leave empty to hide the tip option.
DASHBOARD_TIP_LIGHTNING_ADDRESS=paypaul@paulscode.com

# ── Alerting (optional webhook for security events) ──
# Slack/Discord-compatible webhook for security alerts. Leave empty to
# disable. DNS for the host is re-resolved at request time to defeat
# rebind attacks; private/loopback targets are refused.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_EVENTS=login_failed,tor_fallback,lnd_disconnect,rate_limit_bypass,rate_limit_degraded,auth_brute_force,csrf_violation,audit_chain_broken,audit_anchor

# ── Audit Log ──
# Days to retain audit log entries. A daily Celery task prunes expired
# rows and rewrites the hash chain. 0 = keep forever.
AUDIT_LOG_RETENTION_DAYS=90

# ── CORS ──
# JSON list of allowed origins (empty = CORS disabled)
CORS_ORIGINS=
# Example: CORS_ORIGINS=["http://localhost:3000","https://your-dashboard.example.com"]

# ── Sign / Verify Message ──
# Opt-in API endpoints for signing arbitrary messages with on-chain
# address keys (BIP-322 / BIP-137) or the LN node identity key (zbase32).
# When false, the matching API route is NOT mounted (404 to probes).
# The dashboard Sign/Verify modal works regardless of these flags.
# Defaults are ``true`` because both routes require admin bearer auth
# and are per-key rate-limited; flip to ``false`` to 404 the routes
# entirely if the deployment never needs programmatic message signing.
ENABLE_SIGN_ADDRESS_API=true
ENABLE_SIGN_NODE_API=true

# Maximum message length accepted by sign and verify endpoints.
SIGN_MESSAGE_MAX_CHARS=4096

# If false, audit log records only the SHA-256 hash and length of signed
# messages. Set true to also store the plaintext (privacy trade-off).
SIGN_AUDIT_RECORD_MESSAGE=false

# Sign-rate sliding-window cap (per API key, per dashboard session).
# Sign ops fail CLOSED on Redis errors regardless of these values.
SIGN_RATE_LIMIT_PER_HOUR=30
SIGN_RATE_LIMIT_DASHBOARD_PER_HOUR=60

# Source for the dashboard Sign-form address autocomplete dropdown.
# One of: txn_history (default — recent on-chain destinations),
#         wallet_addresses (full LND-known address list, heavier),
#         off (no dropdown — free-text only).
SIGN_ADDRESS_AUTOCOMPLETE=txn_history

# ── LNURL / Lightning Address ──
# Outbound HTTP fetches for LNURL-pay and Lightning Address resolution.
# Tri-state Tor preference:
#   auto  → use the LND_TOR_PROXY iff LND_REST_URL is a .onion address (default;
#           operators using Tor for LND almost always want the same posture for
#           LNURL fetches so the recipient never sees the dashboard's egress IP)
#   true  → always route LNURL HTTP via LND_TOR_PROXY
#   false → never force Tor for clearnet hosts (.onion recipients still go via Tor)
LNURL_FORCE_TOR=auto
# Accept plain http:// for clearnet recipients. Default false; only enable for
# local development or a deliberate hairpin to a self-hosted clearnet endpoint.
# .onion hosts may use http:// regardless because Tor terminates the encryption.
LNURL_ALLOW_HTTP=false
# SSRF defence: block RFC1918 / loopback / link-local / ULA hosts. Set to true
# only for regtest harnesses that need to talk to a private LNURL service.
LNURL_ALLOW_PRIVATE_HOSTS=false
# Hard cap on response body bytes from any LNURL endpoint. Recipients that
# return more than this are rejected (defence against memory-exhaustion / SSRF
# amplification). 100 KB is well above any well-formed LNURL-pay response.
LNURL_MAX_RESPONSE_BYTES=100000
# Per-request timeout (seconds) for resolve + invoice callbacks.
LNURL_RESOLVE_TIMEOUT_SECONDS=15.0
# Server-side opaque-handle TTL (seconds) used to bridge /lnurl/resolve and
# /lnurl/invoice without trusting the client to re-supply LNURL params.
LNURL_HANDLE_TTL_SECONDS=300
# Idempotency cache for /lnurl/invoice: dedupes accidental double-clicks on
# Continue. Keyed on (handle, amount_sats, comment). Set to 0 to disable.
LNURL_INVOICE_CACHE_TTL_SECONDS=30

# ── BOLT 12 ──
# gRPC target of the bare-LDK onion-message gateway daemon. In docker-compose
# this is set to ``bolt12-gateway:50061`` automatically; leave empty to disable.
BOLT12_GATEWAY_GRPC=
BOLT12_GATEWAY_TIMEOUT_SECONDS=10.0
# Shared bearer token for the gateway gRPC surface. When the gateway has
# BOLT12_GATEWAY_TOKEN set, every wallet RPC must carry the same value here or
# the gateway rejects with UNAUTHENTICATED. Empty on both ends = unauthenticated
# channel — only safe inside a private docker network. REQUIRED when
# BOLT12_ENABLED=true and DEBUG=false: the wallet refuses to dial the gateway
# unauthenticated in that mode. ``start.sh`` auto-generates a token on first
# run; rotate by replacing the value below on BOTH the api and bolt12-gateway
# sides (docker-compose injects the same env var into both containers).
BOLT12_GATEWAY_TOKEN=
# ── Optional: mTLS on the wallet ↔ gateway gRPC channel ──
# Off by default. When ALL of the path triples below are set, the wallet
# uses ``grpc.aio.secure_channel`` with ssl credentials built from the
# listed PEM files, and the gateway requires every client to present a
# cert signed by ``BOLT12_GATEWAY_TLS_CA_CERT``. The bearer-token auth
# above is still applied on top — two independent layers, two independent
# revocation surfaces. See docs/bolt12.md → "Optional: mTLS" and
# ``scripts/gen_bolt12_certs.sh`` for cert generation.
# Set the host directory holding ca.pem / server.pem / server.key /
# client.pem / client.key, then set the in-container paths below. Default
# host dir is ``./bolt12-gateway/certs``; override with BOLT12_CERTS_DIR.
# BOLT12_CERTS_DIR=./bolt12-gateway/certs
#
# Gateway-side (consumed by the bolt12-gateway container):
# BOLT12_GATEWAY_TLS_CA_CERT=/etc/bolt12-gateway/certs/ca.pem
# BOLT12_GATEWAY_TLS_SERVER_CERT=/etc/bolt12-gateway/certs/server.pem
# BOLT12_GATEWAY_TLS_SERVER_KEY=/etc/bolt12-gateway/certs/server.key
#
# Wallet-side (consumed by api + celery-worker):
# BOLT12_GATEWAY_TLS_CA_CERT=/etc/bolt12-gateway/certs/ca.pem
# BOLT12_GATEWAY_TLS_CLIENT_CERT=/etc/bolt12-gateway/certs/client.pem
# BOLT12_GATEWAY_TLS_CLIENT_KEY=/etc/bolt12-gateway/certs/client.key
# Override the TLS SNI / cert hostname when dialing by something other
# than the SAN on server.pem (default SAN is DNS:bolt12-gateway).
# BOLT12_GATEWAY_TLS_SERVER_NAME=bolt12-gateway
# Master kill-switch — even with BOLT12_GATEWAY_GRPC set, the runtime stays
# offline unless this is true. Defaults to enabled in the start.sh wizard
# because the typical deployment receives Lightning payouts (e.g. mining-pool
# payouts) over BOLT 12. Set to false to fully disable inbound
# BOLT 12 traffic if you do not need it.
BOLT12_ENABLED=true
# Auto-peer well-known payers + always-on bootstrap OM peers. When true
# (default), at offer-issuance the gateway pre-dials the payer's node if
# the offer description matches a registered payer (e.g. a recognised
# payout-memo prefix). Independently of any offer, the gateway also keeps
# a sticky connection to a small set of universally-gossiped OM-capable
# bootstrap peers (currently ACINQ + LNBIG) so that any counterparty
# CLN/LDK can route a reply back to us through nodes it already has in
# its gossip graph. Without this, a payer's CLN may fail with "no address
# known for peer" when trying to deliver to a freshly-minted offer. The registries
# live in app/services/bolt12/well_known_payers.py. Set to false only if
# you have restricted egress and want full control of which peers the
# gateway dials.
BOLT12_AUTO_PEER_WELL_KNOWN_PAYERS=true
# Allow inbound BOLT 12 invoice_request messages that do NOT reference one
# of your published offers (the BOLT 12 "refund" / direct-payment flow).
# With this off (default), the wallet only mints invoices for invreqs whose
# offer_issuer_id matches a wallet-issued offer. With it on, any onion-message
# peer can ask the wallet to mint a BOLT 12 invoice for an arbitrary amount;
# the inbound payment is attributed to the dashboard sentinel API key.
# Most operators don't need this — enable only if you know you want to receive
# direct (offer-less) BOLT 12 payments.
BOLT12_ACCEPT_OFFERLESS_INVREQS=false
# Per-payer rate limit for inbound BOLT 12 invreqs. Keyed on
# ``invreq_payer_id`` (or, when missing, the gateway's ``recv_id``). Set
# count to 0 to disable. Window is in seconds.
BOLT12_INBOUND_RATE_LIMIT_COUNT=30
BOLT12_INBOUND_RATE_LIMIT_WINDOW_SECONDS=60
# Global cap on inbound invreq rate across all payers (sliding window
# over the same window seconds above). Defends against per-payer-id
# rotation bypass — CLN's default fetchinvoice generates a fresh
# payer_id per call, making the per-peer cap effectively per-invreq.
# Bounded [0, 10000]. 0 disables.
BOLT12_INBOUND_RATE_LIMIT_GLOBAL_COUNT=300
# Concurrent inbound-mint cap. The rate limit bounds rate; this bounds
# CONCURRENCY so a burst that fits inside the rate-limit window can't
# fan out into unbounded simultaneous LND mint calls. Bounded [1, 256].
BOLT12_INBOUND_MAX_CONCURRENT_MINTS=16
# Acquire-timeout (seconds) for the inbound-mint semaphore. Past this,
# the invreq is dropped with an audit row. Bounded [1, 60].
BOLT12_INBOUND_MINT_ACQUIRE_TIMEOUT_S=5
# Hard cap (msat) on individual inbound BOLT 12 invoices the responder will
# mint. Defence against abusive offer-less peers tying up large amounts of
# inbound liquidity. Set to 0 to disable. Default 100k sats.
BOLT12_INBOUND_MAX_AMOUNT_MSAT=100000000
# Minimum number of real (non-dummy) hops in the blinded paths the responder
# embeds in minted invoices. 1 makes the introduction node our direct LN peer
# — fine when that peer is a well-connected routing hub, but a routability
# dead end if our peer is a small-graph LSP endpoint (payers must reach a
# leaf node through the public graph). 2 shifts the introduction node one
# hop upstream (a peer-of-peer), so payers aim at a hub instead. We
# automatically fall back to 1 hop if LND can't build any path at the
# requested length, so this is safe to default high. Bounded [1, 8].
BOLT12_BLINDED_PATH_MIN_REAL_HOPS=2
# Maximum number of blinded paths LND embeds in a minted invoice. 2 is
# the sweet spot: one primary + one fallback introduction node. Going
# higher bait-traps sender-side MPP splitters (notably CLN's `pay`) into
# fragmenting small payments — with more paths advertised, CLN can split
# off a tiny shard that can't clear an upstream htlc_minimum_msat,
# sinking the whole payment. On small-graph
# topologies LND often only finds 1-2 unique introductions anyway, so
# extra slots just pad with duplicates. Bounded [1, 8].
BOLT12_BLINDED_PATH_MAX_PATHS=2
# Comma-separated (or JSON array) hex pubkeys to omit from blinded paths
# LND builds for minted invoices. Defaults to Boltz
# (026165850492521f4ac8abd9bd8088123446d126f648ca35e60f88177dc149ceb2),
# which gossips itself as a routing node but reserves outbound for its
# swap engine and consistently returns temporary_channel_failure on third-
# party forwarding attempts. Extend the list with any other swap-only /
# non-routing nodes you discover. Malformed entries are silently skipped.
BOLT12_BLINDED_PATH_OMIT_NODES=026165850492521f4ac8abd9bd8088123446d126f648ca35e60f88177dc149ceb2
# Periodic push of LND-known peer addresses to the gateway's in-memory
# cache. Load-bearing for the gateway's Event::ConnectionNeeded handler —
# without it, an outbound onion-message reply destined for a peer we're
# not already connected to (the common case for a payer's reply-
# path introduction node) gets buffered and silently dropped on LDK's
# teardown timer. Interval (seconds) controls the push cadence. Set to 0
# to disable the push task entirely (handler will still warn on miss).
# Bounded [0, 86400]. Default 1 h tracks LND's gossip cadence.
BOLT12_GATEWAY_NODE_ADDRESS_REFRESH_INTERVAL_S=3600
# Hard ceiling on the number of nodes the push includes. The LND graph
# can have ~50k entries; we sort by channel count (descending) and take
# the top N so the most-likely reply-path intermediates land on the
# gateway first. ~5000 entries × ~100 B each = ~500 KB per push,
# comfortably under any gRPC payload limit. Bounded [100, 50000].
BOLT12_GATEWAY_NODE_ADDRESS_MAX_NODES=5000
# Real-time LND settlement subscriber. When true, a background task
# streams GET /v2/invoices/subscribe from LND and flips matching
# Bolt12Invoice rows OPEN → PAID immediately. When false, the reconcile
# cron (60 s cadence) is the only path; settlement state stays stale
# for up to a minute. Useful kill-switch during incident response.
BOLT12_SETTLEMENT_SUBSCRIBER_ENABLED=true
# Retention (days) for terminal Bolt12InvoiceRequest / Bolt12Invoice
# rows. After this age and when status is terminal AND the linked
# offer is not active, the daily cleanup task deletes them. Audit-log
# rows preserved independently. Bounded [7, 3650]. Default 90 days
# (one quarter — covers accounting + plausible incident windows).
BOLT12_REQUEST_RETENTION_DAYS=90
BOLT12_INVOICE_RETENTION_DAYS=90
# htlc_max-vs-balance drift alert threshold. The blinded path
# max_htlc_msat LND advertises derives from the gossiped channel
# max_htlc policy, which is typically set once at channel open and
# never updated against the live remote_balance. When the ratio
# advertised/receivable rises above this value, a periodic check
# logs a WARN line + emits a bolt12_htlc_max_drift_detected audit
# row so operators can correlate against subsequent payment
# failures. Default 1.5x — generous enough for normal balance
# fluctuation, tight enough to catch a real over-claim where the
# advertised htlc_max exceeds the live receivable balance. Set to a
# large value (e.g. 100.0) to effectively disable. Bounded [1.0, 100.0].
BOLT12_HTLC_MAX_DRIFT_RATIO_ALERT=1.5
# Telemetry: stream LND's /v2/router/subscribehtlcs so we can
# attribute payment failures to "HTLC reached us and we rejected
# it" vs "died upstream". Emits structured audit rows when an
# HTLC event matches one of our BOLT 12 payment_hashes. Disable
# only in split deployments where the wallet can't reach the
# router endpoint.
BOLT12_HTLC_EVENT_SUBSCRIBER_ENABLED=true
# Telemetry: capture per-channel balance + gossiped-policy
# snapshot inside Bolt12Invoice.channel_state_snapshot at mint
# time. ~500 B per row. Lets a post-mortem reconstruct the exact
# channel state context of the failed payout WITHOUT needing
# the original LND env preserved.
BOLT12_CHANNEL_SNAPSHOT_AT_MINT_ENABLED=true
# Telemetry: settlement watchdog window (minutes). When an
# inbound invoice has been OPEN this long after mint, emit a
# one-shot bolt12_invoice_settle_timeout audit row so operators
# proactively notice "we minted but the payer never paid"
# instead of waiting for the payer's failure report. 0 disables.
# Bounded [0, 1440].
BOLT12_INVOICE_SETTLE_WATCHDOG_MINUTES=5
# htlc_max clamp safety buffer (parts-per-million subtracted
# from live remote_balance when clamping advertised htlc_max per
# blinded path). 10_000 ppm = 1% headroom. Bounded [0, 100_000].
BOLT12_HTLC_MAX_SAFETY_BUFFER_PPM=10000
# Drop paths whose clamped htlc_max is below the
# requested amount before returning the invoice to the payer.
BOLT12_DROP_UNDERSIZED_PATHS=true
# Refresh each path's encoded fees / htlc-bounds from
# the intro's current gossip BEFORE the BOLT 12 invoice is serialised
# and signed. Closes the LND add_blinded_invoice → stale
# per-channel-policy cache gap, where a stale cache encodes a fee
# budget below an intermediate hop's current real fee, so the
# forwarded HTLC arrives short. Default ON; flip off only if
# it itself starts to misfire.
BOLT12_BLINDED_PATH_REFRESH_POLICY_FROM_GOSSIP=true
# PAYINFO safety margin. Pads the encoded
# proportional_fee_rate above gossip by this many ppm so the payer
# over-quotes an intermediate hop's actual deduction, which can
# exceed its gossiped policy. Default 1000 ppm gives roughly 2x
# headroom over the small undisclosed margins seen in practice.
# 0 disables. Bounded [0, 100_000].
BOLT12_BLINDED_PATH_PAYINFO_SAFETY_MARGIN_PPM=1000
# Base-msat companion to the ppm margin. On large HTLCs a
# proportional margin absorbs an intermediate hop's undisclosed fee,
# but on tiny HTLCs the undisclosed extra is dominated by what looks
# like a fixed min-fee floor, which a proportional margin can't cover.
# A flat 1,500-msat base margin (raised from 1,000 on 2026-06-26
# after a multi-hop intro was observed deducting ~367 msat extra)
# gives every payment ≥1.5 sat of absolute headroom regardless of
# size. Per-payment cost 0.0015 sat, negligible. 0 disables.
# Bounded [0, 100_000].
BOLT12_BLINDED_PATH_PAYINFO_SAFETY_MARGIN_BASE_MSAT=1500
# Probe each blinded path for liveness (intro
# reachable + relevant channel active) before advertising it.
# OFF by default — adds ~1 LND RTT per path per mint.
BOLT12_PROBE_PATHS_BEFORE_MINT=false
# Prefer paths through different intro nodes. When
# multiple paths share an intro, only the best (lowest fee) is
# kept. Reduces single-intro-failure topologies.
BOLT12_PATH_DIVERSITY_ENFORCE=true
# Half-open per-intro circuit breaker (in-memory).
# Resets on wallet restart. Tunables match the standard
# closed/open/half-open pattern.
BOLT12_PATH_BREAKER_ENABLED=true
BOLT12_PATH_BREAKER_FAILURES_TO_OPEN=2
BOLT12_PATH_BREAKER_INITIAL_COOLDOWN_S=600
BOLT12_PATH_BREAKER_COOLDOWN_CAP_S=86400
# Pigeonhole pairing for the clamp's
# terminal-channel identification. When N paths and N channels,
# pair them (cheaper path ↔ smaller channel). Catches the
# multi-hop case that the other strategies miss. Default on.
BOLT12_PATH_PIGEONHOLE_PAIRING_ENABLED=true
# Option B-adaptive: when the primary-depth mint
# produces paths whose intros are ALL marked "open" by the
# breaker, retry the mint at the alternative depth (1 ↔ 2) and
# pick whichever set has at least one healthy intro. Adds one
# LND round-trip when triggered (rare for healthy operation);
# the unused invoice is cancelled. Set to false only if you
# want the responder to never make more than one LND mint per
# invreq.
BOLT12_ADAPTIVE_DEPTH_FALLBACK_ENABLED=true
# BOLT 12 subscriber Tor-resilience. When httpx
# raises a transport-class error on the long-lived stream to
# LND over Tor (ProxyError "TTL expired", ReadError, Remote
# ProtocolError), fire SIGNAL NEWNYM to roll dirty circuits
# and reconnect on a short fixed backoff instead of escalating
# to the exponential ceiling. Throttled by
# TOR_NEWNYM_MIN_INTERVAL_S (default 60 s).
BOLT12_SUBSCRIBER_NEWNYM_ON_TRANSPORT_ERROR=true
BOLT12_SUBSCRIBER_TRANSPORT_ERROR_BACKOFF_S=2.0
# Polling-mode subscribers. ``true`` skips the
# long-lived h2 streams to LND entirely; the settlement
# subscriber runs ``reconcile_open_invoices`` on a tight timer
# instead. Trades settle latency (ms → poll-interval seconds)
# for stream resilience on Tor-unstable deployments. The HTLC
# event subscriber becomes a no-op in this mode (LND has no
# polling REST equivalent for ``link_fail_event``).
BOLT12_SUBSCRIBER_POLLING_MODE_ENABLED=false
BOLT12_SUBSCRIBER_POLLING_INTERVAL_S=5
# When the polling-mode setting above is at its
# default ``false``, auto-detect onion-only LND deployments and
# flip polling on for them. Set to ``false`` if you've explicitly
# chosen ``false`` for the setting above and want it honoured.
BOLT12_SUBSCRIBER_POLLING_MODE_AUTO_DETECT=true
# Periodic ``bolt12_subscriber_heartbeat``
# audit row per active subscriber so silently-broken subscribers
# are distinguishable from "no activity". Seconds; 0 disables.
BOLT12_SUBSCRIBER_HEARTBEAT_INTERVAL_S=300
# Pre-emptive ``GET /v1/getinfo`` warmup before
# opening each long-lived subscriber stream — surfaces dead
# pool connections here instead of mid-stream.
BOLT12_SUBSCRIBER_WARMUP_PROBE_ENABLED=true
# Periodic HSFETCH of our LND onion to track
# HS-descriptor freshness. Seconds; 0 disables. Clearnet-only
# deployments can set to 0 to skip — the probe would just fail.
LND_HS_DESCRIPTOR_PROBE_INTERVAL_S=600
# Per-channel uptime tracker poll interval.
# Tighter than keepalive's 60s so chronic flappers surface. 0
# disables.
LND_CHANNEL_UPTIME_TRACK_INTERVAL_S=30
# Channel-flap detector poll interval. Catches
# sub-minute active→inactive transitions that the 60s keepalive
# misses; feeds the same NEWNYM-burst trigger. 0 disables.
LND_CHANNEL_FLAP_DETECT_INTERVAL_S=5
# Inbound-symptom HS supervisor. Fires SIGHUP
# Tor when subscribers can't keep a stream alive long enough —
# the strongest wallet-side mitigation for "peers can't reach
# our HS" symptoms. Settings tune the detection signature and
# throttle. ``window_s``: rolling window for failure counting.
# ``failure_threshold``: transport errors in window before fire.
# ``healthy_lifetime_s``: a stream lasting at least this long
# in the window blocks firing (Tor is intermittently working).
# ``sighup_throttle_s``: minimum gap between SIGHUPs. SIGHUP is
# heavyweight (drops every Tor circuit) so we fire it sparingly.
BOLT12_INBOUND_SUPERVISOR_ENABLED=true
BOLT12_INBOUND_SUPERVISOR_TICK_INTERVAL_S=30
BOLT12_INBOUND_SUPERVISOR_WINDOW_S=300
BOLT12_INBOUND_SUPERVISOR_FAILURE_THRESHOLD=10
BOLT12_INBOUND_SUPERVISOR_HEALTHY_LIFETIME_S=30.0
BOLT12_INBOUND_SUPERVISOR_SIGHUP_THROTTLE_S=3600
# Channel-flap signal threshold. Channel
# active→inactive transitions are rarer than subscriber transport
# errors so a lower count trips SIGHUP. In polling-mode (auto-
# enabled for onion-only LNDs) this is the supervisor's primary
# signal source because subscribers don't stream.
BOLT12_INBOUND_SUPERVISOR_FLAP_THRESHOLD=3
# HSFETCH-failure signal threshold. A
# single sustained-failure signal in the supervisor window fires
# SIGHUP — peers can't find us via the HS DHT.
BOLT12_INBOUND_SUPERVISOR_HS_FETCH_FAILURE_THRESHOLD=1
# Consecutive HSFETCH failures before the
# probe starts emitting supervisor signals. Set to 0 to disable.
LND_HS_DESCRIPTOR_FAILURE_SUPERVISOR_THRESHOLD=3
# Inbound-disconnect-burst NEWNYM trigger.
# lnd_keepalive watches num_inactive_channels for 0→positive
# transitions (peers disconnecting from our HS). When the
# count crosses ``LND_INBOUND_BURST_NEWNYM_THRESHOLD`` within
# ``LND_INBOUND_BURST_WINDOW_S``, fires NEWNYM to roll our HS
# circuit pool. Set the threshold to 0 to disable.
LND_INBOUND_BURST_NEWNYM_THRESHOLD=2
LND_INBOUND_BURST_WINDOW_S=300
# Cap on in-flight outbound invoice_request calls the orchestrator holds at
# once. Each slot pins a Future + builder closure for up to one timeout, so a
# slow-recipient flood (or compromised admin key) could otherwise pin memory.
# Surfaces as 503 at the REST layer when exceeded.
BOLT12_MAX_PENDING_REQUESTS=64
# Defence-in-depth caps on TLV decoding for inbound onion-message payloads.
# REST entry points already cap raw bytes via Pydantic; these protect the
# parser itself against giant-record / record-flood DoS payloads crafted by
# hostile onion-message peers.
BOLT12_MAX_PAYLOAD_BYTES=65536
BOLT12_MAX_TLV_RECORDS=512
BOLT12_MAX_TLV_VALUE_BYTES=8192
# Defensive ceiling on the encoded BOLT 12 invoice the responder returns
# to the gateway. The onion-message reply envelope has its own hard
# limit (~32 KB after onion overhead); minting larger than that gets
# silently dropped or fragmented. With BOLT12_BLINDED_PATH_MAX_PATHS=2
# and a normal description, the encoded invoice is ~3-4 KB. Bound
# operator misconfiguration (e.g. raising max_paths to 8 with long
# descriptions). Bounded [4096, 65536]. Default 32 KB.
BOLT12_MAX_OUTBOUND_INVOICE_BYTES=32768
# When true, BIP-353 resolution probes ``dnssec-failed.org`` once per
# resolver bootstrap and refuses to trust the upstream if it rubber-stamps
# AD=1 on the bogus name. Costs one extra DNS round-trip per process.
# Default-on because mis-pointed resolvers silently break the BIP-353 trust
# model.
BOLT12_BIP353_VALIDATE_RESOLVER=true

# ══════════════════════════════════════════════════════════════════════
# Anonymize (LN/on-chain mixer feature — see docs/anonymize.md)
# ══════════════════════════════════════════════════════════════════════
# The anonymize feature lets users mix UTXOs via Boltz submarine + reverse
# swaps with Tor isolation, MPP fragmentation, amount binning, optional
# private-channel hop, and (strongest tier) a Liquid round-trip with Confidential
# Transactions amount-blinding. All of it ships behind ``ANONYMIZE_ENABLED``.

# Master switch. Opt-in / OFF by default — this subsystem handles wallet
# seeds and keys for coinjoin-style mixing, so a fresh install does not
# enable it unprompted. Set true to mount the feature at the dashboard
# `/anonymize` tab and `POST /dashboard/api/anonymize/*` endpoints.
ANONYMIZE_ENABLED=false
# Refuse to start the anonymize service when the wallet is not configured
# to route LND through Tor. Strongly recommended (default true). Set false
# only for development against a regtest LND where Tor is unavailable.
ANONYMIZE_REQUIRE_TOR=true
# Refuse any non-`.onion` endpoint at startup (Boltz, chain backend, DoH,
# NTP). Default true — leave as true for production deployments.
ANONYMIZE_ENFORCE_ONION_ONLY_EGRESS=true

# ── Amount limits + bin set ──
# Min / max session amount in sats. The wizard quantizes the requested
# amount DOWN to the nearest published bin (— uniform amounts
# defeat amount-correlation across the two swap legs).
ANONYMIZE_MIN_SAT=50000
ANONYMIZE_MAX_SAT=10000000
# Comma-separated bin set in sats. Sessions are admitted only at one of
# these amounts; the wizard rounds the user's request down. Changing
# the bin set during the lifetime of a deployment is supported via the
# `anonymize_bin_set_history` migration; consult docs/anonymize.md.
# Default: 10k / 25k / 50k / 100k / 250k / 500k / 1M / 2.5M / 5M / 10M sat.
ANONYMIZE_AMOUNT_BINS_SAT=10000,25000,50000,100000,250000,500000,1000000,2500000,5000000,10000000

# ── Randomized session-dwell delays ──
# After the source-side leg completes, the wallet holds the session in
# its dwell state for a uniformly-random duration in [min, max] before
# starting the exit-side leg. The randomization defeats per-session
# timing correlation between input and output.
#
# Lightning sources use the "default" pair (1-6 hours by default).
# On-chain sources use the longer "onchain-interleg" pair (6-48 hours
# by default); the floor is intentionally higher because on-chain
# sources have a public funding-tx timestamp the observer can pivot
# from. Don't lower the on-chain floor below ~1 hour for mainnet.
#
# For e2e testing on regtest you can safely shrink these to seconds —
# RESTORE them before any production deployment.
ANONYMIZE_DEFAULT_DELAY_MIN_S=3600
ANONYMIZE_DEFAULT_DELAY_MAX_S=21600
ANONYMIZE_ONCHAIN_MIN_INTERLEG_DELAY_S=21600
ANONYMIZE_ONCHAIN_MAX_INTERLEG_DELAY_S=172800

# ── Tor SOCKS listener layout ──
# Each call-site class (Boltz submarine, Boltz reverse, Liquid, chain
# backend, BIP-353 DoH, quote-cache refresh, etc.) uses a distinct
# SOCKS listener so the operator cannot fingerprint the wallet across
# calls. The listeners must be configured in your tor daemon — see
# docs/anonymize.md "Per-call-site Tor isolation" for the
# ``torrc`` snippet.
ANONYMIZE_TOR_SOCKS_PORTS=boltz_submarine=9050,boltz_reverse=9051,liquid=9052,chain_backend=9053,bip353_dns=9054,quote_cache_refresh=9055,chain_backend_general=9056,chain_backend_anonymize=9057

# ── Clock-skew probe sources ──
# Comma-separated URLs the recurring clock-skew probe HEADs over Tor.
# The server ``Date`` header from each is compared to the local clock;
# the median delta becomes the wallet's measured skew. The create
# endpoint refuses sessions when no measurement is available
# (``clock_skew_within_threshold = False``), so this MUST resolve to
# at least one reachable endpoint.
#
# Leave blank to auto-fall-back to the signed
# ``app/services/anonymize/clock_skew_sources.json`` registry, which
# ships with a curated set of **independent** onions (DuckDuckGo,
# ProtonMail, Tor Project) that have no swap-operator role — so a
# single compromised swap operator cannot simultaneously poison the
# clock-skew measurement and a swap leg.
#
# The probe takes the median across responding sources, so 3+ entries
# defeat one misbehaving source. Set this var to override the curated
# default with your own list.
ANONYMIZE_CLOCK_SKEW_PROBE_SOURCES=

# Create-time clock-skew tolerance in milliseconds. The probe takes
# N samples per tick (ANONYMIZE_CLOCK_SKEW_SAMPLES_PER_TICK, below)
# and statistically aggregates them to recover sub-second precision
# from the second-resolution HTTP ``Date`` header. With N=12 the
# aggregation's own standard error is ~85 ms, but the probe's half-
# RTT midpoint compensation assumes a symmetric round-trip — Tor
# circuits routinely have hundreds of ms of inbound/outbound path
# asymmetry. The 1000 ms default tolerates that real-world floor;
# tightening it on Tor will refuse on correctly-synced clocks. Swap
# expiry timing is HOURS, so 1000 ms of clock error is irrelevant
# for actual swap-safety.
ANONYMIZE_MAX_CLOCK_SKEW_MS=1000
# Runtime (mid-flight) tolerance — looser because some clock drift
# is expected over a multi-hour session. Used by
# self-broadcast checks.
ANONYMIZE_MAX_RUNTIME_CLOCK_SKEW_MS=5000

# Statistical-aggregation probe knobs. The probe collects
# N samples spread across W seconds, then takes a trimmed median
# (drops top/bottom ``TRIM_FRACTION``) to recover sub-second
# precision from second-resolution HTTP ``Date`` headers. Lowering
# ``SAMPLES_PER_TICK`` to 1 reverts to the legacy single-sample
# behaviour (useful as a rollback knob if the aggregation path
# misbehaves on a specific deployment).
ANONYMIZE_CLOCK_SKEW_SAMPLES_PER_TICK=12
ANONYMIZE_CLOCK_SKEW_SAMPLE_WINDOW_S=20.0
ANONYMIZE_CLOCK_SKEW_MIN_SAMPLES_FOR_DECISION=6
ANONYMIZE_CLOCK_SKEW_TRIM_FRACTION=0.15

# ── At-rest encryption keys (REQUIRED in production) ──
# These default to empty so a misconfigured deployment fails loud at
# startup rather than silently shipping un-encrypted state. Generate
# each with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Comma-separated lists support rotation overlap (active key first).

# Fernet bundle for the keyed-BLAKE2b hash that backs destination-
# reuse detection. Required for the wallet to refuse a destination that
# was used by a previous session.
ANONYMIZE_REUSE_DETECTION_KEY_FERNET=

# Per-cookie/user/IP cap on session-create calls per hour.
# Defaults to 100 (sustainable single-user retry pace) which still
# defeats compromised-cookie spam attacks; lower this on multi-user
# deployments where each tenant should be tightly capped.
ANONYMIZE_REUSE_CHECK_RATE_LIMIT_PER_HOUR=100

# Fernet bundle for hop-idempotency-key derivation. Required so
# crash-recovery doesn't re-issue the same external side-effect.
ANONYMIZE_HOP_IDEMPOTENCY_KEY_FERNET=

# Fernet bundle for the quote-token HMAC key. Required for the
# wallet to sign / verify quote tokens.
ANONYMIZE_QUOTE_TOKEN_HMAC_KEY_FERNET=
ANONYMIZE_QUOTE_TOKEN_HMAC_KEY_ROTATION_DAYS=1
ANONYMIZE_QUOTE_TOKEN_HMAC_KEY_RETENTION_DAYS=8

# Fernet bundle for the per-operator quote-cache signature. Required
# when the anonymize service is enabled: cached operator fee / limit
# data is HMAC-signed with this key and verified on read, and the
# service refuses to start without it (minimum 32 characters).
ANONYMIZE_QUOTE_CACHE_SIGNING_KEY_FERNET=

# Fernet bundle for the step-up re-auth cookie subject
# blinding. Required when decoy / refund-UTXO override flows are used.
ANONYMIZE_STEPUP_COOKIE_HMAC_KEY_FERNET=

# ── On-chain decoy seed ──
# Separate BIP-86 taproot seed for decoy outputs. The wallet refuses
# to start when this is unset on an on-chain deployment unless
# `ANONYMIZE_DECOY_SEED_REQUIRED=false` (regression path; logged CRITICAL).
# Operator runbook: separate-backup-envelope discipline applies — mix-ups
# between this and the primary LND seed are the primary operational risk.
ANONYMIZE_DECOY_SEED_FERNET=
# 32+ bytes of base64 random, used as the HMAC key for per-session
# derivation index assignment. Generate: openssl rand -base64 32
ANONYMIZE_DECOY_SEED_ACCOUNT_KEY=
# Set to false ONLY to opt out of decoy-seed-required startup gate (the
# wallet still loads, but decoy flows are unavailable). Strongest-tier
# deployments remove this opt-out entirely.
ANONYMIZE_DECOY_SEED_REQUIRED=true

# ── Operator-registry signing ──
# Comma-separated maintainer release-key fingerprints trusted to
# sign `app/services/anonymize/operators.json`. Two formats accepted:
#   * GPG (RSA or EdDSA): 40 hex chars (v4) or 64 hex chars (v5).
#     Wallet verifies via system `gpg` against the bundled pubkey at
#     app/services/anonymize/maintainer.asc.
#   * Raw ed25519: 64 hex chars of the 32-byte public key. Wallet
#     verifies via cryptography.hazmat.primitives.asymmetric.ed25519.
# The dispatcher auto-detects based on signature file format.
#
# Default below pins the v1 release-maintainer key (Paul Lamb,
# https://paulscode.com — public key at
# https://paulscode.com/.well-known/paulscode.asc, bundled in-repo).
# Forks should replace this with their own maintainer fingerprint
# AND replace app/services/anonymize/maintainer.asc with their key.
# Lightning-only deployments without a curated registry can leave this
# blank — the loader falls back to the empty-registry single-operator
# path. See docs/anonymize_operator_diversity.md for the ceremony.
ANONYMIZE_REGISTRY_RELEASE_KEY_FINGERPRINTS=FF76D4843EBD7FA06D92DC0CB8AB7B8E7E280E1A
# Path the loader reads. Defaults to the in-repo location; override
# only if shipping signed registries from elsewhere.
ANONYMIZE_REGISTRY_SIG_PATH=app/services/anonymize/operators.sig

# k-of-n threshold signing (off by default; opt-in for
# stronger maintainer-compromise resistance). See
# docs/anonymize.md "Threshold-signed registry".
ANONYMIZE_REGISTRY_REQUIRE_THRESHOLD_SIG=false
ANONYMIZE_REGISTRY_THRESHOLD_K=2
ANONYMIZE_REGISTRY_THRESHOLD_SIG_PATHS=

# ── Liquid round-trip hop ──
# Opt-in CT-blinded L-BTC dwell between the LN-side legs. Defends
# against amount correlation by the Boltz operator(s). When the master
# switch below is on, ``start.sh`` automatically adds
# ``docker-compose.liquid.yml`` to the compose invocation so an
# ``elementsd`` (and optionally ``electrs-liquid``) come up alongside
# the wallet. The dashboard hides every Liquid-related UI element when
# this is false.
#
# Disk + RAM footprint (Liquid mainnet, mid-2026):
#   elementsd        ~75 GB disk, ~9.6 GiB RAM. Elements Core holds
#                    the full ~3.9M-block index in memory (dynafed
#                    headers are 1–4 KiB each, far larger than
#                    Bitcoin's). This is the dominant Liquid memory cost.
#   electrs-liquid   ~75 GB disk, ~2.4 GiB RAM serving (~3.7 GiB peak
#                    during the one-time initial index build).
#                    The image is built with the slim-headers patch
#                    (liquid-overlay/patches/0001-slim-headers.patch),
#                    which keeps only per-block header metadata in RAM
#                    and reads full headers from RocksDB on demand;
#                    without it the unpatched upstream needs 10–16 GiB.
#
# So the local Liquid stack adds ~12 GiB RAM (elementsd-dominated).
# See docs/anonymize.md "Sizing the host" for the full breakdown: a
# 32 GiB host already running the base node stack (Bitcoin + electrs +
# Mempool + LND) can self-host the Liquid indexer. Pointing at an
# external Liquid Electrum endpoint instead drops the local cost to
# elementsd alone (~10 GiB).
ANONYMIZE_LIQUID_ENABLED=false
# Umbrella overlay switch. Mirrors ANONYMIZE_LIQUID_ENABLED so the
# start.sh up/restart/logs/stop commands know to include
# docker-compose.liquid.yml; kept as a separate name because operators
# running an externally-managed elementsd may want the wallet to USE
# Liquid (ANONYMIZE_LIQUID_ENABLED=true) without start.sh launching
# its own overlay (ENABLE_LIQUID=false).
ENABLE_LIQUID=false
# Whether ``start.sh`` should ALSO activate the ``liquid-indexer``
# compose profile, which brings up the embedded ``electrs-liquid``
# container. Off by default mainly for its ~75 GB disk; with the
# slim-headers patch its RAM cost is modest (~2 GiB) — elementsd
# (~9.6 GiB) is the heavier half of the Liquid stack.
#
# When false: only elementsd comes up locally, and
# ANONYMIZE_LIQUID_ELECTRUM_URL MUST point at an external Liquid
# Electrum endpoint (Blockstream operates public ones; or run
# electrs-liquid on a separate beefier host).
#
# When true: the wallet self-hosts the indexer. First boot triggers
# Liquid IBD — plan for ~1 hour of block fetching plus another
# ~30–60 minutes of post-IBD RocksDB compaction. The wallet's
# Anonymize tab shows a "Liquid backend not ready yet" banner
# throughout that window.
ENABLE_LIQUID_INDEXER=false
# elementsd RPC credentials. Auto-generated by ``start.sh`` when the
# wizard enables Liquid. The RPC interface is bound to the internal
# Docker network only, so these never leave the host, but the
# password must be a strong random value (placeholder rejected at
# startup). ELEMENTSD_RPC_ALLOW_CIDR is the in-overlay subnet the
# electrs-liquid container connects from; the default matches the
# overlay's compose network.
ELEMENTSD_RPC_USER=elements
ELEMENTSD_RPC_PASSWORD=
ELEMENTSD_RPC_ALLOW_CIDR=172.20.0.0/16
# Fernet bundle for the SLIP-77 Liquid master blinding key. Required
# when ANONYMIZE_LIQUID_ENABLED=true. Use SEPARATE backup envelope
# from the primary LND seed and the decoy seed.
#
# ⚠ BACKUP IMMEDIATELY — without this value the wallet cannot
#   unblind in-flight Liquid hop outputs and cannot construct
#   claims or cooperative refunds for them. Funds remain
#   eventually recoverable via Boltz's L-BTC timeout path, but
#   every in-flight session is stuck until that timeout fires.
#   start.sh writes a narrow backup file
#   (liquid-seed-backup-<timestamp>.txt, mode 0600) when it
#   generates a fresh value — move that file to offline storage
#   alongside the SECRET_KEY backup.
ANONYMIZE_LIQUID_SEED_FERNET=
# SLIP-77 seed derivation version (0 or 1). 0 (default) seeds the Liquid
# blinding/spending keys from the Fernet first-key bytes directly, which
# ties Liquid spend authority to the at-rest encryption key. 1 derives the
# seed through a domain-separated HKDF so the two are independent. Switch
# to 1 only while NO Liquid funds are in flight — the two versions produce
# different on-chain Liquid addresses, so changing it mid-session would
# strand a dwell output until its Boltz timeout refund fires.
ANONYMIZE_LIQUID_SEED_DERIVATION_VERSION=0
# Electrum/electrs-liquid endpoint. Same URL shape as LND_ELECTRUM_URL.
# Default points at the overlay's internal Docker host; set to an
# external endpoint if you manage your own elementsd + electrs-liquid.
ANONYMIZE_LIQUID_ELECTRUM_URL=tcp://electrs-liquid:50001
# Override the built-in L-BTC asset id (mainnet/testnet defaults ship
# in code). Required for regtest deployments.
ANONYMIZE_LIQUID_BTC_ASSET_ID=
# Runtime safety gate — refuses LN↔L-BTC swap-create unless set to
# true. Default ``true`` because the end-to-end regtest harness has
# been validated in-repo against the upstream Boltz regtest stack
# (see tests/integration/anonymize/test_liquid_e2e_regtest.py). Flip
# to false only if you suspect the integration has regressed and
# want the wallet to refuse Liquid swaps as a hard kill-switch
# independent of ANONYMIZE_LIQUID_ENABLED.
ANONYMIZE_LIQUID_INTEGRATION_VERIFIED=true
# Liquid fee-rate cache TTL in seconds. The recurring fee-oracle tick
# refreshes the cache on this cadence; quote-create reads the cached
# value. On a fresh deployment, the wallet refuses Liquid quotes with
# 503 ``no_cache`` until the first refresh completes. For e2e testing
# you can lower this to force a faster initial refresh.
ANONYMIZE_LIQUID_FEE_RATE_CACHE_TTL_S=300
# Boltz chain-swap operator OVERRIDES for the LN→L-BTC and L-BTC→LN
# legs. Empty (default) → the wallet resolves both legs from the
# signed operator registry (app/services/anonymize/operators.json),
# mirroring the LN↔on-chain leg-picking policy:
#   * LN→L-BTC ("reverse-analog" — the leg whose output dwells in
#     the L-BTC anonymity set): canonical Boltz preferred.
#   * L-BTC→LN ("submarine-analog"): most-recently-audited
#     non-canonical operator (Middleway → Eldamar fallback). Falls
#     back to canonical if no diverse operator is registered.
# Set either variable to a full URL to PIN that leg to a specific
# operator instead of using registry-driven selection (useful for
# regtest or an externally-managed Boltz instance).
BOLTZ_CHAIN_LN_TO_LBTC_API_URL=
BOLTZ_CHAIN_LBTC_TO_LN_API_URL=

# ── BIP-353 destination resolution + deposit acceptance ──
# DoH endpoint for resolving user@domain payment handles at quote
# time. MUST be a non-logging provider with DNSSEC validation
# (Mullvad + Quad9 are the supported defaults). Empty falls back to
# the built-in default below.
ANONYMIZE_BIP353_DOH_ENDPOINT=https://dns.mullvad.net/dns-query
ANONYMIZE_BIP353_CACHE_MIN_TTL_S=86400

# When set, the wallet mints a per-session BIP-353 handle
# (`<random>@<domain>`) for ext-lightning BOLT 12 deposits so depositors
# can paste `user@domain` into a BIP-353-capable wallet. The operator
# is responsible for publishing the emitted TXT records to DNS; the
# wallet does not call any external DNS provider. Leave blank to
# disable per-session handle generation (BOLT 12 offer alone still
# works for depositors with BOLT 12-capable wallets).
ANONYMIZE_BIP353_DEPOSIT_DOMAIN=

# Default deposit method for ext-lightning sessions: `bolt11` (legacy
# single-use blinded payment-request) or `bolt12` (per-session BOLT 12
# offer). The quote endpoint accepts a per-quote override.
ANONYMIZE_EXT_LIGHTNING_DEPOSIT_METHOD=bolt11

# ── Audit / retention / score knobs (all have sensible defaults) ──
# Most operators do not need to touch these. Override only if you have
# a specific deployment posture in mind. The defaults are documented
# in app/core/config.py and docs/anonymize.md.

# Days to keep destination-address ciphertext + chain anchors before
# redacting via gc.py. Default 7 days.
ANONYMIZE_DESTINATION_RETENTION_DAYS=7
# Hard-delete after this many days (irreversible). Default 365.
ANONYMIZE_HARD_DELETE_AFTER_DAYS=365

# Tier concurrency caps. One in-flight `strong` session blocks
# all new sessions; `moderate` admits up to 2; `weak` admits up to 3.
ANONYMIZE_TIER_CONCURRENCY_CAP=weak=3,moderate=2,strong=1

# Max sessions one identity may create per rolling hour (admission
# sliding window). Default 10. Raise both this and the concurrency cap
# above when iterating in testing.
ANONYMIZE_CREATE_WINDOW_MAX_PER_HOUR=10

# Hard-refusal flags. Default false at the on-chain tier (step-up
# re-auth required); intended true at the strongest tier.
ANONYMIZE_REFUSE_DECOY_OVERRIDE_SPENDS=false
ANONYMIZE_REFUSE_REFUND_OVERRIDE_SPENDS=false
